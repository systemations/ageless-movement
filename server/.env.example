# Copy to .env and fill in. Never commit the real .env.

NODE_ENV=development
PORT=3001

# Datastore is SQLite, encrypted at rest in production via DB_ENCRYPTION_KEY
# below (SQLite3MultipleCiphers). A Postgres move was scoped and deferred — see
# SECURITY.md L4 — so DATABASE_URL is unused for now.
# DATABASE_URL=postgresql://localhost:5432/ageless_movement

# REQUIRED IN PRODUCTION. Must be at least 32 chars of random data.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If unset in development, the server generates an ephemeral secret at boot
# (sessions invalidated on every restart).
JWT_SECRET=
JWT_EXPIRES_IN=7d

# REQUIRED IN PRODUCTION. Encrypts the SQLite database at rest (SECURITY.md L4).
# At least 16 chars; generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set it ONCE and keep it stable: the DB is encrypted with this key, and an
# existing plaintext DB is migrated to encrypted on first boot. Changing the key
# later makes the database unreadable. Unset in development = plaintext DB.
DB_ENCRYPTION_KEY=

# --- External services (added later in the pre-launch infra pass) ---
# RESEND_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SENTRY_DSN=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
