node_modules/
dist/
.env
server/data/
.DS_Store
*.log
# SQLite working copy — real DB lives in server/data/ (gitignored) and on
# Render's persistent disk in production. This pattern catches any stray
# .db files elsewhere in the tree.
*.db
*.db-journal
*.db-shm
*.db-wal

# Exception: the bundled production content snapshot MUST ship in the repo so
# a fresh Render disk can seed itself on first boot (see server/src/db/pool.js).
!server/seed/ageless-seed.db
