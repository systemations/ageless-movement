{
  "appId": "com.agelessmovement.app",
  "appName": "Ageless Movement",
  "webDir": "dist",
  "server": {
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#060D1A",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
