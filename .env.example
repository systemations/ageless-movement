PORT=3001
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Public base URL of the SPA, used to build links inside transactional emails
# (password reset). Dev defaults to http://localhost:5173 if unset; set this
# in prod to the real client origin, e.g. https://app.agelessmovement.com
APP_BASE_URL=http://localhost:5173

# Transactional email via Resend (https://resend.com). Leave RESEND_API_KEY
# unset locally to use the dev fallback (reset links are logged to the server
# console instead of being emailed).
RESEND_API_KEY=
# Must be an address on a domain verified in Resend for real delivery.
# Defaults to Resend's shared test sender (onboarding@resend.dev), which only
# delivers to the Resend account owner's own email.
EMAIL_FROM=Ageless Movement <noreply@agelessmovement.com>
